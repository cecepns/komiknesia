# Base URL API Node (tanpa trailing slash) — harus bisa reach POST /api/ikiru/cron-sync
IKIRU_CRON_BASE_URL=https://api-be.komiknesia.my.id

# Feed Ikiru: latest | project
IKIRU_CRON_FEED_TYPE=latest

# Opsional: Bearer token jika nanti API dilindungi
# IKIRU_CRON_SECRET=

# Timeout HTTP per request sync (ms). Sync bisa lama; default 15 menit.
# IKIRU_CRON_TIMEOUT_MS=900000

# Ekspresi cron (node-cron). Default: page1 tiap jam :00; page2 tiap 3 jam :30 (hindari tabrakan dengan job jam-an).
# CRON_PAGE1_SCHEDULE=0 * * * *
# CRON_PAGE2_SCHEDULE=30 */3 * * *

# Zona waktu jadwal, mis. Asia/Jakarta
# CRON_TZ=Asia/Jakarta

# Jalankan kedua job sekali saat proses start (untuk tes)
# RUN_ON_START=false
