# Base URL API Node (tanpa trailing slash) — disarankan local backend agar tidak tergantung TLS publik
IKIRU_CRON_BASE_URL=http://127.0.0.1:3001

# Feed Ikiru: latest | project
IKIRU_CRON_FEED_TYPE=latest

# Opsional: Bearer token jika nanti API dilindungi
# IKIRU_CRON_SECRET=

# Timeout HTTP per request sync (ms). Sync bisa lama; default 15 menit.
# IKIRU_CRON_TIMEOUT_MS=900000

# Ekspresi cron (node-cron).
# Default:
# - page1 delta + saveToS3=true: tiap 10 menit
# - page1 full + saveToS3=true: tiap 1 jam
# - page2 full + saveToS3=false: tiap 2 jam
# - page3 full + saveToS3=false: tiap 3 jam
# CRON_PAGE1_DELTA_SCHEDULE=*/10 * * * *
# CRON_PAGE1_FULL_SCHEDULE=0 * * * *
# CRON_PAGE2_FULL_SCHEDULE=0 */2 * * *
# CRON_PAGE3_FULL_SCHEDULE=0 */3 * * *

# Zona waktu jadwal, mis. Asia/Jakarta
# CRON_TZ=Asia/Jakarta

# Jalankan kedua job sekali saat proses start (untuk tes)
# RUN_ON_START=false
