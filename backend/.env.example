# Scrape/sync Ikiru: default login di backend/utils/ikiruSession.js (Whyuu / komiknesia).
# Set env berikut untuk override akun lain (keduanya harus di-set jika override):
# IKIRU_AUTH_EMAIL=
# IKIRU_AUTH_PASSWORD=
# Alias untuk email/username:
# IKIRU_AUTH_USER=
# Opsional: lewati login Ikiru (gunakan request publik + cookie CF jika ada)
# IKIRU_SKIP_AUTH=false
# Opsional: base origin Ikiru (default: https://03.ikiru.wtf)
# IKIRU_ORIGIN=https://04.ikiru.wtf

# Puppeteer helper untuk refresh cookie Cloudflare Ikiru:
# IKIRU_CF_TARGET_URL=https://03.ikiru.wtf/latest-update/
# IKIRU_CF_MAX_WAIT_MS=180000
# IKIRU_CF_HEADLESS=true
# IKIRU_CF_DEBUG_SCREENSHOT=./data/ikiru-cf-debug.png
# IKIRU_CF_CLEAR_ON_FAIL=false
# Auto refresh saat request scrape/sync kena block Cloudflare:
# IKIRU_CF_AUTO_REFRESH_ON_BLOCK=true
