# Base URL API Node (tanpa trailing slash) — disarankan local backend agar tidak tergantung TLS publik
IKIRU_CRON_BASE_URL=http://127.0.0.1:3001

# Feed Ikiru: latest | project
IKIRU_CRON_FEED_TYPE=latest

# Opsional: Bearer token (hanya dikirim ke API; backend saat ini tidak memvalidasi — siap jika nanti dilindungi)
# IKIRU_CRON_SECRET=

# Login + Cloudflare untuk scrape ada di proses BACKEND (bukan di .env ikiru-cron):
# IKIRU_AUTH_EMAIL / IKIRU_AUTH_USER, IKIRU_AUTH_PASSWORD, plus cookie CF (admin atau file backend/data/ikiru-cloudflare-cookies.txt).

# Timeout HTTP per request sync (ms). Sync bisa lama; default 15 menit.
# IKIRU_CRON_TIMEOUT_MS=900000

# Ekspresi cron (node-cron), semua job memakai CRON_TZ jika di-set.
# Default: page1 delta tiap 20 menit saveToS3=false; page1 full tiap 1 jam saveToS3=false; page2 full tiap 2 jam saveToS3=false.
# CRON_PAGE1_DELTA_SCHEDULE=*/20 * * * *
# CRON_PAGE1_FULL_SCHEDULE=0 * * * *
# CRON_PAGE2_FULL_SCHEDULE=0 */2 * * *

# Zona waktu jadwal, mis. Asia/Jakarta
# CRON_TZ=Asia/Jakarta

# Jalankan kedua job sekali saat proses start (untuk tes)
# RUN_ON_START=false
